{
  "expo": {
    "name": "Stocky",
    "slug": "controle-estoque",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/favIcon.png",
    "scheme": "stocky",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1C1C1c",
        "foregroundImage": "./src/assets/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.leonardobessa.stocky"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1C1C1C",
          "dark": {
            "backgroundColor": "#1C1C1C"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11d05357-2d7e-434f-8440-ae5ecbe4f5ce"
      }
    }
  }
}
